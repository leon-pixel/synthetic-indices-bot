# Copy to .env — never commit real tokens.

# === DERIV CONNECTION ===
# Demo / virtual account token (Deriv: Account settings → API token)
DERIV_API_TOKEN=

# Optional; default public app id works for many read-only calls
DERIV_APP_ID=1089

# wss://ws.derivws.com/websockets/v3
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3

# Symbol, e.g. R_75, R_100
DERIV_SYMBOL=R_75

# sim = no orders (signals + logs only). deriv = proposal/buy/sell when implemented path is valid.
EXECUTION_MODE=sim


# === EXECUTION ===
# Base stake amount
STAKE=1.0
# Spread in points (sim friction)
SPREAD_POINTS=0.5
# Slippage in points
SLIPPAGE_POINTS=0.3
# Contract duration bounds
CONTRACT_DURATION_MINUTES=10
MIN_CONTRACT_MINUTES=1
MAX_CONTRACT_MINUTES=10
# Currency
CURRENCY=USD

# === DYNAMIC POSITION SIZING ===
# Enable Kelly Criterion position sizing (true/false)
USE_KELLY=false
# Kelly fraction (0.25 = half-Kelly for safety)
KELLY_FRACTION=0.25


# === RISK MANAGEMENT ===
# Risk per trade (% of equity)
RISK_PER_TRADE_PCT=0.35
# Max trades per day
MAX_TRADES_PER_DAY=8
# Max daily loss (% of equity)
MAX_DAILY_LOSS_PCT=2.0
# Max consecutive losses before halt
MAX_CONSECUTIVE_LOSSES=3
# Cooldown between trades (minutes)
COOLDOWN_MINUTES=12
# Trading session hours (UTC)
SESSION_START_UTC_HOUR=8
SESSION_END_UTC_HOUR=20


# === STRATEGY ===
# EMA periods
EMA_FAST=20
EMA_SLOW=50
# RSI settings
RSI_PERIOD=14
RSI_BUY_MAX=35.0  # relaxed from 30 for more signals
RSI_SELL_MIN=65.0  # relaxed from 70 for more signals
# ATR settings
ATR_PERIOD=14
ATR_HIGH_PCT=0.85
ATR_LOW_PCT=0.15
ATR_PCT_WINDOW=288
# TP/SL settings
TP_R_MULTIPLE_MIN=2.0  # increased from 1.2 for better expectancy
TP_R_MULTIPLE_MAX=3.0  # increased from 1.5
SL_ATR_MULT=0.5  # reduced from 1.0 for tighter loss
# Exit settings
MAX_HOLD_MINUTES=8
MIN_HOLD_BARS_FOR_STALL=3
STALL_MFE_ATR_MULT=0.15
# Trailing stop
USE_TRAILING_STOP=true
TRAILING_ATR_MULT=2.0